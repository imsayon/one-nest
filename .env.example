# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=onenest
POSTGRES_PASSWORD=onenest_secret
POSTGRES_DB=onenest
DATABASE_URL=postgresql://onenest:onenest_secret@localhost:5432/onenest

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Gemini (Google AI) ────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Google APIs ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ─── OpenWeather ───────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=

# ─── Amadeus (Flights) ─────────────────────────────────────────────────────────
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# ─── Spotify ───────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# ─── PgAdmin (dev only) ────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@onenest.ai
PGADMIN_PASSWORD=admin
